# GitSnip Environment Configuration
# Copy this file to .env and update with your actual values

# API Keys (Required for backend functionality)
GEMINI_API_KEY=your_gemini_api_key_here
GITHUB_TOKEN=your_github_token_here

# Application Settings
NODE_ENV=production
FLASK_ENV=production

# Ports (Change if needed)
FRONTEND_PORT=80
BACKEND_PORT=5000
PROXY_PORT=8080

# Domain (For production deployment)
DOMAIN=localhost

# Database (Future use)
# DATABASE_URL=postgresql://user:password@localhost:5432/gitsnip

# Redis (Future use for caching)
# REDIS_URL=redis://localhost:6379

# Security (Generate strong secrets for production)
SECRET_KEY=your-secret-key-here
JWT_SECRET=your-jwt-secret-here

# Logging
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# File Upload Limits
MAX_FILE_SIZE=10MB
MAX_REPO_SIZE=100MB

